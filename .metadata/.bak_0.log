		if(!enderecoOptional.isPresent()) {
			return ResponseEntity.status(HttpStatus.NOT_FOUND).body("O endereço pesquisado não foi encontrado!");
		}
		return ResponseEntity.status(HttpStatus.CREATED).body(enderecoOptional.get());
	}
