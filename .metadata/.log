		cliente.setNome(this.nome);
		cliente.setSexo(this.sexo);
		cliente.setDataNasci(this.dataNasci);
		return cliente;
	}
	public void Cliente fromCliente()
	@Override
	public String toString() {
		return "ClienteDto [nome=" + nome + ", sexo=" + sexo + ", dataNasci=" + dataNasci + "]";
	}
	
