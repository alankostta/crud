public class ClienteDto{
	
	@NotBlank
	@NotNull
	@Size(max = 70)
	private String nome;
	@NotNull
	@Size(max = 15)
	private String sexo;
	@NotNull
	@DateTimeFormat(pattern="yyyy-MM-dd")
	private Date dataNasci;
	
